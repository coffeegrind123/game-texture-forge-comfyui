# Host path the Docker daemon bind-mounts for models/input/output/user.
#
# Default (./data) works when the Docker daemon shares this filesystem.
# If the daemon runs on a Windows host (Docker Desktop / WSL), it resolves bind
# mounts on THAT host — point this at the host path, e.g.:
#   TEXFORGE_DATA=//c/users/<username>/path/to/comfyui/data
#
# Copy this file to .env and edit. .env is gitignored.
TEXFORGE_DATA=./data
